# Publish only source code, database schema, and the reviewer README.
*

!/.gitignore
!/README.md

!/backend/
/backend/*
!/backend/pom.xml
!/backend/src/
!/backend/src/**

!/frontend/
/frontend/*
!/frontend/package.json
!/frontend/package-lock.json
!/frontend/index.html
!/frontend/vite.config.js
!/frontend/src/
!/frontend/src/**

!/sql/
/sql/*
!/sql/*.sql

!/scripts/
/scripts/*
!/scripts/test-api.ps1
